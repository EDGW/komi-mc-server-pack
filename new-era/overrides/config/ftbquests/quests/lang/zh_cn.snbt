	quest.0B71DD7F21BD41B8.quest_desc: [
		"言昔时矮人技艺无双，"
		"工匠们铸造无数宝藏，"
		"铁锤落下，如钟回响，"
		"响彻孤山下肃穆殿堂。"
		""
		"山谷之中警钟声洪亮，"
		"致命的烈焰来自北方，"
		"枪矛如林却不敌死亡，"
		"史矛革盘踞孤山宝藏。"
		""
		"    或许可以找找那座叫“孤山”的山脉"
	]
	quest.0B71DD7F21BD41B8.quest_subtitle: "歌谣"
	quest.0BC0ECD7689390CE.quest_desc: [
